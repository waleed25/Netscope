<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Network Summary — {{ report_id }}</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
         max-width: 900px; margin: 40px auto; padding: 0 20px; color: #1a1a2e; }
  h1 { border-bottom: 2px solid #007aff; padding-bottom: 8px; }
  table { width: 100%; border-collapse: collapse; margin: 16px 0; }
  th { background: #f0f4ff; padding: 8px 12px; text-align: left; border-bottom: 2px solid #c0d0ff; }
  td { padding: 8px 12px; border-bottom: 1px solid #e8eaf0; }
  .meta { font-size: 13px; color: #666; margin-bottom: 24px; }
  .stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin: 16px 0; }
  .stat-card { background: #f8f9fa; border: 1px solid #e8eaf0; border-radius: 8px; padding: 16px; }
  .stat-num { font-size: 28px; font-weight: 700; color: #007aff; }
  .stat-label { font-size: 13px; color: #666; }
</style>
</head>
<body>
<h1>Network Traffic Summary</h1>
<div class="meta">Report ID: {{ report_id }} · Generated: {{ generated_at }}</div>

{% if stats is defined %}
<div class="stat-grid">
  <div class="stat-card"><div class="stat-num">{{ stats.total_packets | default(0) }}</div><div class="stat-label">Total Packets</div></div>
  <div class="stat-card"><div class="stat-num">{{ stats.unique_hosts | default(0) }}</div><div class="stat-label">Unique Hosts</div></div>
  <div class="stat-card"><div class="stat-num">{{ stats.protocols | default(0) }}</div><div class="stat-label">Protocols</div></div>
</div>
{% endif %}

{% if top_talkers is defined %}
<h2>Top Talkers</h2>
<table>
  <tr><th>IP</th><th>Packets</th><th>Bytes</th></tr>
  {% for t in top_talkers %}
  <tr><td>{{ t.ip }}</td><td>{{ t.packets }}</td><td>{{ t.bytes }}</td></tr>
  {% endfor %}
</table>
{% endif %}

{% if analysis is defined %}
<h2>AI Analysis</h2>
<pre style="background:#f8f9fa;border:1px solid #e8eaf0;padding:12px;border-radius:4px;white-space:pre-wrap">{{ analysis }}</pre>
{% endif %}
</body>
</html>
