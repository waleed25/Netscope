{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "netscope-backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000,
      "cwd": "backend"
    },
    {
      "name": "netscope-frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "5173", "--host", "127.0.0.1"],
      "port": 5173,
      "cwd": "frontend"
    }
  ]
}
